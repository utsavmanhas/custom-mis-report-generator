# Copy this file to .env.local and paste your real keys.
# .env.local is gitignored; keys never leave your machine.

# ---------- Anthropic (Phase 1 analysis + per-sheet build) ----------
# Get from https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=

# Optional model override. Analysis and sheet building default to claude-opus-4-7.
# ANTHROPIC_MODEL_ANALYZE=claude-opus-4-7
# ANTHROPIC_MODEL_BUILD=claude-opus-4-7

# ---------- Shortcut.ai (alternative Phase 2 builder) ----------
# Get from your Shortcut dashboard. The "Build with Shortcut" button uses this.
# If left blank, the Shortcut button just returns an error - the Claude
# build path still works.
SHORTCUT_API_KEY=
